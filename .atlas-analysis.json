  "keyFeatures": [
    "Nonprofit Minecraft server hosting with flexible plans",
    "RGBirdflop gradient text generator with NPM package",
    "Server optimization tools (Spark Profile, Paper Timings analyzers)",
    "Discord bots (Botflop for timings analysis, BirdTickets for support)",
    "Minecraft utility tools (Banner generator, Animated textures, Flags generator)",
    "Community-focused platform with open source contributions",
    "Free pastebin service (Binflop) for server logs and configs",
    "Multi-language support (i18n) for global accessibility"
  ],
  "publicApiSurface": [
    "generateOutput(options) - Main gradient generation function",
    "rgbDefaults - Default configuration object",
    "hexToRGB(hex) - Convert hex color to RGB array",
    "rgbToHex(rgb) - Convert RGB array to hex string",
    "ColorGradient - Gradient generator class",
    "disperseColors(colors) - Distribute colors evenly",
    "sortColors(colors) - Sort colors by position",
    "getShadowColors(rgbStore) - Generate shadow colors for text",
    "AnimTABUtils - Utilities for TAB plugin animations",
    "GradientType - Linear, radial, and custom gradient types"
  ]
